{
  "name": "@tronvercel/auth",
  "version": "0.1.0",
  "description": "Tronvercel auth — shared local-password + OIDC authentication for Express apps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyle079/tronvercel-ui.git",
    "directory": "packages/auth"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "express": ">=4.18.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express-session": "^1.18.0",
    "openid-client": "^5.7.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.19.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.57.0",
    "express": "^4.21.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
