{
  "name": "@tronvercel/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Tronvercel UI — shared React component library (shadcn/ui + Tailwind) with the restrained-Tron/Vercel theme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyle079/tronvercel-ui.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/tronvercel-ui.cjs",
  "module": "./dist/tronvercel-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tronvercel-ui.js",
      "require": "./dist/tronvercel-ui.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@radix-ui/react-checkbox": ">=1.0.0",
    "@radix-ui/react-radio-group": ">=1.0.0",
    "@radix-ui/react-select": ">=2.0.0",
    "@radix-ui/react-switch": ">=1.0.0",
    "@radix-ui/react-toast": ">=1.0.0",
    "lucide-react": ">=0.400.0",
    "clsx": ">=2.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@radix-ui/react-checkbox": { "optional": true },
    "@radix-ui/react-radio-group": { "optional": true },
    "@radix-ui/react-select": { "optional": true },
    "@radix-ui/react-switch": { "optional": true },
    "@radix-ui/react-toast": { "optional": true },
    "lucide-react": { "optional": true },
    "clsx": { "optional": true },
    "tailwind-merge": { "optional": true }
  },
  "devDependencies": {
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.16",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.11",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.4.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-dts": "^3.9.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
